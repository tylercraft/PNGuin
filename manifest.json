{
  "manifest_version": 3,
  "name": "PNGuin",
  "version": "1.0",
  "description": "Slide through webpages and snag high-res PNGs.",
  "permissions": ["activeTab", "contextMenus", "debugger", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
